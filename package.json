{
  "name": "saliguard",
  "version": "1.0.0",
  "description": "SaliGuard - AI-Powered Salinity Intrusion Early Warning System (monorepo root)",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:backend": "npm --prefix backend run dev",
    "dev:ai": "uvicorn app:app --reload --port 8000 --app-dir ai_engine",
    "dev": "concurrently -n backend,ai -c blue,green \"npm:dev:backend\" \"npm:dev:ai\""
  },
  "devDependencies": {
    "concurrently": "^9.2.3"
  }
}
