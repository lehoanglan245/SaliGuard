# Mẫu biến môi trường cho production (docker-compose.prod.yml).
# Sao chép thành .env trên VPS rồi điền giá trị THẬT. KHÔNG commit file .env.

# --- PostgreSQL / TimescaleDB ---
DB_USER=postgres
DB_PASSWORD=doi_mat_khau_manh_o_day
DB_NAME=saliguard

# --- Trạm phần cứng thật ---
REAL_STATION_ID=ST001

# --- Chatbot (Google Gemini) ---
GEMINI_API_KEY=dien_gemini_api_key_o_day
# CHAT_MODEL=gemini-2.5-flash

# --- Domain ---
# Domain API (Caddy sẽ xin chứng chỉ HTTPS cho domain này). Trỏ A record về IP VPS.
API_DOMAIN=api.saliguard.example.com

# --- CORS ---
# Domain dashboard trên Cloudflare Pages (nhiều domain phân tách bằng dấu phẩy).
CORS_ORIGIN=https://saliguard.pages.dev,https://saliguard.example.com
