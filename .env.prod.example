# Mẫu biến môi trường cho production (docker-compose.prod.yml).
# Sao chép thành .env trên VPS rồi điền giá trị THẬT. KHÔNG commit file .env.

# --- PostgreSQL / TimescaleDB ---
DB_USER=postgres
DB_PASSWORD=doi_mat_khau_manh_o_day
DB_NAME=saliguard

# --- Trạm phần cứng thật ---
REAL_STATION_ID=ST001

# --- Chatbot (Google Gemini) ---
GEMINI_API_KEY=AQ.Ab8RN6JW8ENNDJLx-ZYgOft0FlTtzZ2JjwEXsGzoGAigMjBBwQ
CHAT_MODEL=gemini-3.1-flash-lite

# --- Email cảnh báo (Gmail SMTP - dùng App Password, không phải mật khẩu thường) ---
